{
  "$id": "urn:zys:schema:content-manifest:1",
  "title": "Hero Lineup Offline Content Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appVersion",
    "schemaVersion",
    "gameDataVersion",
    "simulatorVersion",
    "assetVersion",
    "createdAt",
    "minimumAppVersion",
    "statistics",
    "files"
  ],
  "properties": {
    "appVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "gameDataVersion": { "type": "string", "minLength": 1 },
    "simulatorVersion": { "type": "string", "minLength": 1 },
    "assetVersion": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "minimumAppVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
    "statistics": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "size", "sha256"],
        "properties": {
          "path": { "type": "string", "pattern": "^(TextAsset|Sprite|defaults|schemas)/" },
          "kind": { "enum": ["data", "sprite", "default", "schema"] },
          "size": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
